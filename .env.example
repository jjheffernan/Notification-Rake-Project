# Copy to .env — defaults match config.py and pyproject.toml [tool.notification-rake]
GOTIFY_URL=http://gotify:80
GOTIFY_TOKEN=
GOTIFY_ADMIN_PASS=change-me
GOTIFY_PUBLIC_URL=http://127.0.0.1:8081

POSTGRES_USER=rake
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rake
DATABASE_URL=postgresql://rake:change-me@db:5432/rake

HASURA_ADMIN_SECRET=change-me
HASURA_URL=http://hasura:8080

NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODE_USER_AGENT=notification-rake/0.1.0

CRAIGSLIST_SEARCH_RSS=https://sfbay.craigslist.org/search/cta?format=rss&query=toyota+camry

# Yahoo Auctions JP (phase 0+) — https://developer.yahoo.co.jp/
YAHOO_APP_ID=
YAHOO_AUCTION_API_BASE=https://auctions.yahooapis.jp/AuctionWebService/V2
YAHOO_VEHICLE_AUCCAT=26360
YAHOO_INGEST_PAGE_SIZE=50
YAHOO_REQUESTS_PER_DAY=45000
DEFAULT_DEST_COUNTRY=US
FX_USD_JPY=150.0
FX_USD_GBP=0.79
FX_USD_EUR=0.92

# Public listings dashboard (no sign-in) + admin-only /admin routes
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change-me-dashboard-secret
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Admin tool URLs (shown on admin dashboard)
ADMINER_URL=http://127.0.0.1:8082
METABASE_URL=http://127.0.0.1:3000
METABASE_INTERNAL_URL=http://metabase:3000
GRAFANA_URL=http://127.0.0.1:3001
PROMETHEUS_INTERNAL_URL=http://prometheus:9090
JUPYTER_URL=http://127.0.0.1:8888
JUPYTER_INTERNAL_URL=http://jupyter:8888

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# RAKE_SCRIPTS_DIR=/app/scripts

JUPYTER_TOKEN=change-me
JUPYTER_PORT=8888

# Meilisearch full-text search (auto = use when healthy, else Postgres)
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_PUBLIC_URL=http://127.0.0.1:7700
MEILISEARCH_API_KEY=change-me-dev-key
SEARCH_ENGINE=auto

COPART_ENABLED=true
COPART_API_MODE=auto
COPART_INGEST_LIMIT=50
EU_MARKETPLACES_ENABLED=true
EU_INGEST_LIMIT=50
CARSANDBIDS_ENABLED=true
CARSANDBIDS_API_MODE=auto
CARSANDBIDS_INGEST_LIMIT=50
IMAGE_PROXY_ENABLED=true

# Market data external sources (optional — enrich /m pages)
FRED_API_KEY=
CIS_AUTOMOTIVE_JWT=
CIS_AUTOMOTIVE_API_KEY=
CIS_AUTOMOTIVE_API_SECRET=
CIS_AUTOMOTIVE_REGION=REGION_STATE_CA
CIS_AUTOMOTIVE_SALES_MONTH=

LOG_LEVEL=INFO
